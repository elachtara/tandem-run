  // FORM LOGIC
  // CAROUSEL
  let currentSlide = 0;
  const totalSlides = 4;

  function updateCarousel() {
    document.getElementById('carouselTrack').style.transform = `translateX(-${currentSlide * 100}%)`;
    document.querySelectorAll('.carousel-dot').forEach((dot, i) => {
      dot.classList.toggle('active', i === currentSlide);
    });
  }

  function moveCarousel(dir) {
    currentSlide = (currentSlide + dir + totalSlides) % totalSlides;
    updateCarousel();
  }

  function goToSlide(n) {
    currentSlide = n;
    updateCarousel();
  }

  // Auto-advance every 5 seconds
  setInterval(() => moveCarousel(1), 5000);

  function handleSignup(source) {
    let email;
    if (source === 'hero') {
      email = document.getElementById('hero-email').value.trim();
      if (!email || !email.includes('@')) {
        document.getElementById('hero-email').style.borderColor = '#e8a820';
        document.getElementById('hero-email').focus();
        return;
      }
      document.getElementById('hero-form-wrap').style.display = 'none';
      document.getElementById('hero-success').style.display = 'flex';
      submitToSheets({ source: 'hero', email });
    } else {
      email = document.getElementById('footer-email').value.trim();
      if (!email || !email.includes('@')) {
        document.getElementById('footer-email').style.borderColor = '#e8a820';
        document.getElementById('footer-email').focus();
        return;
      }
      const payload = {
        source: 'footer',
        name: document.getElementById('footer-name').value.trim(),
        email,
        pace: document.getElementById('footer-pace').value,
        time: document.getElementById('footer-time').value,
        neighborhood: document.getElementById('footer-neighborhood').value
      };
      const btn = document.querySelector('.footer-btn');
      btn.disabled = true;
      btn.textContent = "You're on the list!";
      btn.style.background = '#3d3b36';
      document.getElementById('footer-success').style.display = 'flex';
      submitToSheets(payload);
    }
  }

  function submitToSheets(data) {
    const SCRIPT_URL = 'YOUR_APPS_SCRIPT_URL_HERE';
    if (SCRIPT_URL === 'YOUR_APPS_SCRIPT_URL_HERE') return;
    fetch(SCRIPT_URL, {
      method: 'POST',
      body: JSON.stringify(data)
    }).catch(err => console.error('Submission error:', err));
  }

  document.getElementById('hero-email').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') handleSignup('hero');
    this.style.borderColor = '';
  });

  document.getElementById('footer-email').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') handleSignup('footer');
    this.style.borderColor = '';
  });

  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', function(e) {
      e.preventDefault();
      const t = document.querySelector(this.getAttribute('href'));
      if (t) t.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
